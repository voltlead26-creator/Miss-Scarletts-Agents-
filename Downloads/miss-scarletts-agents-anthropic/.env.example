# ANTHROPIC_API_KEY: required. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Optional overrides — sensible defaults are baked in if you omit these.
# SMITH_MODEL: model used for Agent Smith's own reasoning + delegation calls.
SMITH_MODEL="claude-sonnet-4-6"
# SPECIALIST_MODEL: model used for each consulted specialist agent.
# You can point this at a cheaper/faster model (e.g. a Haiku-tier model) if
# you want to cut cost on routine specialist calls while keeping Smith sharp.
SPECIALIST_MODEL="claude-sonnet-4-6"
# MAX_TOKENS: per-call output cap, shared by Smith and specialist calls.
MAX_TOKENS="1500"
# PORT: local port for the Express + WebSocket server.
PORT="3001"

# Frontend-only deploys (for example Netlify) can point at a separate backend.
# Leave API origin blank for same-origin local development or Netlify deploys.
VITE_API_ORIGIN=""
